{
  "manifest_version": 3,
  "name": "bro.job",
  "version": "1.0.0",
  "description": "Instantly summarise any job description and check your fit — without leaving the page.",

  "options_page": "options.html",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "https://bro-job.vercel.app/"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "bro.job"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}